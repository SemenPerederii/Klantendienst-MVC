@model ArtikelToevoegViewModel
@{
    ViewData["Title"] = "Artikel Toevoegen";
}
<h1>Nieuw Artikel</h1>
<form asp-action="Toevoegen" class="form-control" method="post" novalidate>
    <input asp-for="Artikel.EAN" class="form-control" hidden/>
    
    <div class="form-group">
        <label asp-for="Artikel.Naam"></label>
        <span asp-validation-for="Artikel.Naam" class="text-danger">*</span>
        <input required asp-for="Artikel.Naam" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.Beschrijving"></label>
        <span asp-validation-for="Artikel.Beschrijving" class="text-danger">*</span>
        <input required asp-for="Artikel.Beschrijving" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.Prijs"></label>
        <span asp-validation-for="Artikel.Prijs" class="text-danger"></span>
        <input asp-for="Artikel.Prijs" class="form-control" type="number" step=".01" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.GewichtInGram"></label>
        <span asp-validation-for="Artikel.GewichtInGram" class="text-danger"></span>
        <input asp-for="Artikel.GewichtInGram" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.Bestelpeil"></label>
        <span asp-validation-for="Artikel.Bestelpeil" class="text-danger"></span>
        <input asp-for="Artikel.Bestelpeil" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.MinimumVoorraad"></label>
        <span asp-validation-for="Artikel.MinimumVoorraad" class="text-danger"></span>
        <input asp-for="Artikel.MinimumVoorraad" value="10" class="form-control" />
        <label asp-for="Artikel.MaximumVoorraad"></label>
        <span asp-validation-for="Artikel.MaximumVoorraad" class="text-danger"></span>
        <input asp-for="Artikel.MaximumVoorraad" value="100" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.Voorraad"></label>
        <span asp-validation-for="Artikel.Voorraad" class="text-danger"></span>
        <input asp-for="Artikel.Voorraad" value="10" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.Levertijd"></label>
        <span asp-validation-for="Artikel.Levertijd" class="text-danger"></span>
        <input asp-for="Artikel.Levertijd" class="form-control" value="1" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.MaxAantalInMagazijnPLaats"></label>
        <span asp-validation-for="Artikel.MaxAantalInMagazijnPLaats" class="text-danger"></span>
        <input asp-for="Artikel.MaxAantalInMagazijnPLaats" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Artikel.LeveranciersId"></label>
        <span asp-validation-for="Artikel.LeveranciersId" class="text-danger"></span>
        <input asp-for="Artikel.LeveranciersId" class="form-control" value="1" />
    </div>
    <div class="form-group">
        <label asp-for="Categorieën"></label>
        <div>
        @for (int i = 0; i < Model.Categorieën.Count; i++)
            {
             <input type="hidden" asp-for="Categorieën[i].Id"/>
             <input type="checkbox" asp-for="Categorieën[i].Gekozen"/>
             <input type="hidden" asp-for="Categorieën[i].Naam" />
             <label>@Model.Categorieën[i].Naam</label>
             <label> </label>
            }
        </div>
           </div>
    <div class="form-group">
        <button type="submit" value="Aanmaken" class="btn-primary">Aanmaken</button>
    </div>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}