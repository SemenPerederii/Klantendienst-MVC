@model ArtikelViewModel
@{
    ViewData["Title"] = "Overzicht Artikelen";
}
<h1 class="d-flex justify-content-center">@ViewData["Title"]</h1>
<form asp-action="ZoekenOpFilter" method="post">

    <div class="dropdown mb-4 " 
         data-bs-auto-close="false">

        <button class="btn btn-primary dropdown-toggle"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">
            Zoekfilters
        </button>

        <div class="dropdown-menu p-4" style="min-width: 420px;">

            <!-- ID -->
            <div class="mb-3">
                <label class="form-label">Id</label>
                <input asp-for="Id" class="form-control" />
            </div>

            <!-- EAN -->
            <div class="mb-3">
                <label class="form-label">EAN</label>
                <input asp-for="EAN" class="form-control" />
            </div>

            <!-- Naam -->
            <div class="mb-3">
                <label class="form-label">Naam</label>
                <input asp-for="Naam" class="form-control" />
            </div>

            <!-- Prijs -->
            <div class="row mb-3">
                <div class="col">
                    <label class="form-label">Min prijs</label>
                    <input asp-for="MinPrijs" class="form-control" type="text" inputmode="decimal" />
                </div>
                <div class="col">
                    <label class="form-label">Max prijs</label>
                    <input asp-for="MaxPrijs" class="form-control" type="text" inputmode="decimal"/>
                </div>
            </div>


            <!-- In voorraad -->
            <div class="form-check mb-3">
                <input asp-for="InVoorraad" class="form-check-input" />
                <label class="form-check-label">
                    Enkel artikelen in voorraad
                </label>
            </div>

            <!-- Categorieën -->
            <div class="mb-3">
                <button class="btn btn-outline-secondary w-100 text-start"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#catCollapse"
                        aria-expanded="false"
                        aria-controls="catCollapse">
                    Filter categorieën
                </button>

                <div class="collapse mt-2" id="catCollapse">
                    <div class="border rounded p-2" style="max-height: 420px; overflow:auto;">
                        @await Html.PartialAsync("_CategorieFilterTree", Model.Categorieën,
                            new ViewDataDictionary(ViewData) {
                                ["SelectedLeafIds"] = Model.GeselecteerdeCategorieIds
                            })
                    </div>
                </div>
            </div>


            <div class="d-grid">
                <button type="submit" class="btn btn-success">
                    Zoeken
                </button>
            </div>

        </div>
    </div>
</form>



<table class="table table-striped">
    <thead>
        <tr>
            <th>EAN-Code</th>
            <th>Naam</th>
            <th>Beschrijving</th>
            <th>Prijs</th>
            <th>In voorraad</th>
            <th>Categorie(ën)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var artikel in Model.Artikelen.OrderBy(a => a.Naam))
        {
            <tr>
                <td>@artikel.EAN</td>
                <td>@artikel.Naam</td>
                <td>@artikel.Beschrijving</td>
                <td>@artikel.Prijs.ToString("€ #,##0.00")</td>
                <td>@artikel.Voorraad</td>
                <td>
                    <ul>
                        @foreach (var categorie in artikel.Categorieën)
                        {
                            <li><a href="#">@categorie.Naam</a></li>
                        }
                    </ul>
                </td>
                <td><a asp-action="ZetArtikelInactief" asp-route-id="@artikel.ArtikelId" >Zet inactief</a></td>
            </tr>
        }
    </tbody>
</table>

