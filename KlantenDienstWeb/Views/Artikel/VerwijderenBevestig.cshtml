@using KlantenDienstData.Models
@model Artikel
@{
    ViewData["Title"] = "VerwijderenBevestig";
}

<div class="cs-container-verwijderen">
    <h3 class="d-flex justify-content-center">Wil u categorie "@Model.Naam" verwijderen?</h3>

    <div class="d-flex justify-content-center cs-buttons-verwijderen">
        <form asp-action="Verwijderen"
              asp-controller="Artikel"
              method="post"
              style="display:inline">

            <input type="hidden" name="id" value="@Model.ArtikelId" />
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <button type="submit" class="btn btn-primary">
                Verwijderen
            </button>
        </form>

        <a href="javascript:history.back()" class="btn btn-secondary">Annuleren</a>
    </div>
</div>


