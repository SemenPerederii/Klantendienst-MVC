@model CategorieDropdownViewModel

<h1>Categorie Toevoegen</h1>
<br />
<div class="form-group mb-3">
    <label>Hoofdcategorie koppelen</label>
    <select asp-for="GeselecteerdeHoofdcategorieId" asp-items="Model.Categorieen" class="form-control">
        <option value="">- Geen hoofdcategorie -</option>
    </select>
</div>

<div class="form-group mb-3">
    <label asp-for="Naam"></label>
    <input asp-for="Naam" class="form-control" />
    <span asp-validation-for="Naam" class="text-danger"></span>
</div>

<div class="form-group mb-3">
    <label>Subcategorieën</label>

    <div class="row">
        @foreach (var sub in Model.SubCategorieen)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="GeselecteerdeSubCategorieIds"
                           value="@sub.Value"
                           @(Model.GeselecteerdeSubCategorieIds.Contains(int.Parse(sub.Value)) ? "checked" : "") />

                    <label class="form-check-label">
                        @sub.Text
                    </label>
                </div>
            </div>
        }
    </div>
</div>

<button type="submit" class="btn btn-primary">Toevoegen</button>