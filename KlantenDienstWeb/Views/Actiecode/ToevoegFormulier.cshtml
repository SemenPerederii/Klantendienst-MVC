@model Actiecode

@{
    ViewData["Title"] = "Actiecode Toevoegen";
}
<div class="d-flex align-items-center justify-content-center">
    <h1>
        Nieuwe Actiecode
    </h1>
</div>
<form asp-action="Toevoegen" class="form-control container" method="post" novalidate>
    <div class="row mb-4">
        <div class="form-group col-sm-6">
            <label asp-for="Naam"></label>
            <span asp-validation-for="Naam" class="text-danger"></span>
            <input required asp-for="Naam" class="form-control" />
        </div>
        <div class="form-group col-sm-6 text-end">
            <label asp-for="IsEenmalig" class="btn btn-outline-primary">Eenmalig
                <input asp-for="IsEenmalig" class="form-check-input" type="checkbox" />
            </label>
        </div>
    </div>
    <div class="row mb-4">
        <div class="form-group col-sm-6">
            <label asp-for="GeldigVanDatum"></label>
            <span asp-validation-for="GeldigVanDatum" class="text-danger"></span>
            <input asp-for="GeldigVanDatum" class="form-control" type="date" />
        </div>
        <div class="form-group col-sm-6">
            <label asp-for="GeldigTotDatum"></label>
            <span asp-validation-for="GeldigTotDatum" class="text-danger"></span>
            <input asp-for="GeldigTotDatum" class="form-control" type="date" />
        </div>
    </div>
    <div class="row">
        <div class="form-group col-sm">
            <button type="submit" value="Aanmaken" class="btn btn-primary">Aanmaken</button>
            <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
        </div>
    </div>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

