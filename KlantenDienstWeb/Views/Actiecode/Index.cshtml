@model IEnumerable<Actiecode>
@{
    ViewData["Title"] = "Actiecodes";
}

<h1 class="d-flex justify-content-center">@ViewData["Title"]</h1>

<a asp-action="ToevoegenActiecode" asp-controller="Actiecode" class="btn btn-sm btn-primary mb-2">Actiecode Toevoegen</a>

<div class="d-flex gap-2 mb-4">
    <form asp-action="Filter" method="get">
        <div class="dropdown"
             data-bs-auto-close="false">
            <button class="btn btn-primary dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                Zoekfilters
            </button>

            <div class="dropdown-menu col-md-4">
                <div class="d-grid">
                    <button type="submit" class="btn btn-success">
                        Zoeken
                    </button>
                </div>

                <div class="d-grid">
                    <a asp-action="Index" title="Wissen Filters" class="btn btn-secondary">
                        Wis Filters
                        <img src="~/images/deleteBtn.png" class="cs-btnsImg" alt="Wissen Filters" />
                    </a>
                </div>

                <label class="form-label">Filter:</label>
                <select name="filter"
                        class="form-select"
                        onchange="toggleDate(this.value)">
                    <option value="">Kies filter</option>
                    <option value="ActiefNu">Nu actief</option>
                    <option value="NietActiefNu">Niet actief</option>
                    <option value="ExacteDatum">Op datum</option>
                </select>

                <div class="dropdown-menu col-md-4" id="datumContainer" style="display:none">
                    <label class="form-label">Datum</label>
                    <input type="date" name="datum" class="form-control" />
                </div>

            </div>

        </div>
    </form>
</div>



<table class="table table-striped">
    <thead>
        <tr>
            <th>Actiecode</th>
            <th>Van</th>
            <th>Tot</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var actiecode in Model)
    {
        <tr>
            <td>@actiecode.Naam</td>
            <td>@actiecode.GeldigVanDatum.ToString("dd-MM-yyyy")</td>
            <td>@actiecode.GeldigTotDatum.ToString("dd-MM-yyyy")</td>
                <td>
                    <a asp-action="WijzigenActiecode" asp-controller="Actiecode" asp-route-id="@actiecode.ActiecodeId" class="btn btn-sm cs-btns">
                        Wijzigen <img src="/images/editBtn.png" alt="Wijzigen" class="cs-btnsImg" />
            </a></td>
        </tr>
    }
    </tbody>
</table>

<script>
    function toggleDate(value) {
        document.getElementById("datumContainer").style.display = value === "ExacteDatum" ? "block" : "none";
    }
</script>
