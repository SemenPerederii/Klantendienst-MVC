@model PaswoordWijzigenVM
@{
    ViewData["Title"] = "Wijzig wachtwoord";
}
<div class="d-flex align-items-center position-relative m-3">
    <h1 class="position-absolute start-50 translate-middle-x">
        Wachtwoord wijzigen
    </h1>
</div>
<form asp-action="WachtwoordWijzigenDoorvoeren" class="form-control container" method="post">
    <div class="d-grid" style="grid-template-columns: auto; grid-template-rows: auto auto auto;">
        <div style="grid-row: span 3;">
            <div class="row">
                <div class="form-group col-sm">
                    <label asp-for="Emailadres"></label>
                    <input required asp-for="Emailadres" value="@Model.Emailadres" class="form-control" readonly />
                </div>
            </div>
            <div class="row">
                <div class="form-group col-sm">
                    <label asp-for="HuidigPaswoord"></label>
                    <span class="text-danger">*</span>
                    <span asp-validation-for="HuidigPaswoord" class="text-danger"></span>
                    <input asp-for="HuidigPaswoord" class="form-control" step=".01" />
                </div>
            </div>
            <div class="row">
                <div class="form-group col-sm">
                    <label asp-for="NieuwPaswoord"></label>
                    <span class="text-danger">*</span>
                    <span asp-validation-for="NieuwPaswoord" class="text-danger"></span>
                    <input asp-for="NieuwPaswoord" class="form-control" />
                </div>
            <div class="row">
                <div class="form-group col-sm">
                    <label asp-for="BevestigNieuwPaswoord"></label>
                        <span class="text-danger">*</span>
                    <span asp-validation-for="BevestigNieuwPaswoord" class="text-danger"></span>
                    <input asp-for="BevestigNieuwPaswoord"  class="form-control" />
                </div>
            </div>
        </div>
    </div>
    <div class="row mt-2">
        <div class="form-group col-sm">
            <button type="submit" value="Wijzigen" class="btn btn-primary">Wijzigen</button>
        </div>
    </div>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
</form>