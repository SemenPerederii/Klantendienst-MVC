@model Bestelling
@{
    ViewData["Title"] = "BestellingDetails";
    var klantSoort = Model.Klant.Natuurlijkepersonen != null ? "Persoon" : "Bedrijf";
}
<div class="container mt-4">
    <h1>Bestelling #@Model.BestelId</h1>
    <p class="text-muted">Besteldatum: @Model.Besteldatum.ToShortDateString()</p>

    <div class="row mb-4">
        <div class="col-md-6">
            <section class="mb-4">
                <h3>Klantgegevens</h3>
                <dl class="row">
                    <dt class="col-sm-4">Naam</dt>
                    <dd class="col-sm-8">@ViewBag.KlantNaam</dd>

                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">@klantSoort</dd>

                    @if (klantSoort == "Bedrijf" && Model.Klant.Rechtspersonen?.Contactpersonen.Any() == true)
                    {
                        <dt class="col-sm-4">Contactpersonen</dt>
                        <dd class="col-sm-8">
                            <ul class="list-unstyled mb-0">
                                @foreach (var cp in Model.Klant.Rechtspersonen.Contactpersonen)
                                {
                                    <li>@cp.Voornaam @cp.Familienaam (@cp.Functie)</li>
                                }
                            </ul>
                        </dd>
                    }
                </dl>
            </section>
        </div>

        <div class="col-md-6">
            <section class="mb-4">
                <h3>Bestelgegevens</h3>
                <dl class="row">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span>@Model.BestellingsStatus.Naam</span>
                    </dd>

                    <dt class="col-sm-4">Betaalwijze</dt>
                    <dd class="col-sm-8">
                        @switch (Model.BetaalwijzeId)
                        {
                            case 1:
                                <span>Niet Betaald</span>
                                break;
                            case 2:
                                <span>Kredietkaart</span>
                                break;
                            case 3:
                                <span>Overschrijving</span>
                                break;
                            default:
                                <span>-</span>
                                break;
                        }
                    </dd>

                    <dt class="col-sm-4">Betalingscode</dt>
                    <dd class="col-sm-8">@(Model.Betalingscode ?? "-")</dd>

                    <dt class="col-sm-4">Betaald</dt>
                    <dd class="col-sm-8">
                        <input type="checkbox" checked="@Model.Betaald" disabled />
                    </dd>

                    <dt class="col-sm-4">Actiecode gebruikt</dt>
                    <dd class="col-sm-8">
                        @if (Model.ActiecodeGebruikt)
                        {
                            <span>Ja</span>
                        }
                        else
                        {
                            <span>Nee</span>
                        }
                    </dd>

                    @if (Model.Annulatie)
                    {
                        <dt class="col-sm-4">Annulatie</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-danger">Geannuleerd</span>
                            @if (Model.AnnulatieDatum.HasValue)
                            {
                                <br />
                        
                                <p>@Model.AnnulatieDatum.Value.ToShortDateString()</p>
                            }
                        </dd>

                        @if (!string.IsNullOrEmpty(Model.Terugbetalingscode))
                        {
                            <dt class="col-sm-4">Terugbetalingscode</dt>
                            <dd class="col-sm-8">@Model.Terugbetalingscode</dd>
                        }
                    }
                </dl>
            </section>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <section>
                <h3>Facturatieadres</h3>
                <address>
                    @Model.FacturatieAdres.Straat @Model.FacturatieAdres.HuisNummer<br />
                    @Model.FacturatieAdres.Plaats.Postcode @Model.FacturatieAdres.Plaats.PlaatsNaam
                </address>
            </section>
        </div>
        <div class="col-md-6">
            <section>
                <h3>Leveringsadres</h3>
                <address>
                    @Model.LeveringsAdres.Straat @Model.LeveringsAdres.HuisNummer<br />
                    @Model.LeveringsAdres.Plaats.Postcode @Model.LeveringsAdres.Plaats.PlaatsNaam
                </address>
            </section>
        </div>
    </div>

    <section class="mb-4">
        <h2>Bestellijnen</h2>
        @if (Model.Bestellijnen.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Artikel</th>
                            <th>Prijs</th>
                            <th>Aantal</th>
                            <th>Geannuleerd</th>
                            <th class="text-end">Subtotaal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            decimal totaalBedrag = 0;
                        }
                        @foreach (var bestellijn in Model.Bestellijnen)
                        {
                            var subtotaal = bestellijn.Artikel.Prijs * (bestellijn.AantalBesteld - bestellijn.AantalGeannuleerd);
                            totaalBedrag += subtotaal;
                            <tr>
                                <td>@bestellijn.Artikel.Naam</td>
                                <td>@bestellijn.Artikel.Prijs.ToString("C2", System.Globalization.CultureInfo.CreateSpecificCulture("nl-BE"))</td>
                                <td>@bestellijn.AantalBesteld</td>
                                <td>
                                    @if (bestellijn.AantalGeannuleerd > 0)
                                    {
                                        <span class="badge bg-warning">@bestellijn.AantalGeannuleerd</span>
                                    }
                                    else
                                    {
                                        <text>-</text>
                                    }
                                </td>
                                <td class="text-end">@subtotaal.ToString("C2", System.Globalization.CultureInfo.CreateSpecificCulture("nl-BE"))</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="text-end"><strong>Totaal:</strong></td>
                            <td class="text-end"><strong>@totaalBedrag.ToString("C2", System.Globalization.CultureInfo.CreateSpecificCulture("nl-BE"))</strong></td>
                        </tr>
                        <tr>
                            <td colspan="5" class="text-muted text-end">
                                <span>Aantal artikelen: @Model.Bestellijnen.Sum(b => b.AantalBesteld - b.AantalGeannuleerd)</span>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">Lege bestelling</p>
        }
    </section>

    <a asp-action="Index" asp-controller="Bestelling" class="btn btn-secondary">
        Terug naar Bestellingen
    </a>
    <a asp-action="Details" asp-controller="Klant" asp-route-id="@Model.KlantId" class="btn btn-secondary">
        Terug naar Klant
    </a>
</div>