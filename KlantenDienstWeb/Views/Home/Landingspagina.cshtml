@{
    ViewData["Title"] = "Home Page";
}
<main class="container text-center">
    <div class="row">
        <div class="col-sm col-1 card m-4">
            <h2>Artikelbeheer</h2>
            <a class="btn btn-primary m-1" asp-action="Index" asp-controller="Artikel">Alle Artikelen</a>
            <a class="btn btn-primary m-1" asp-action="ToevoegFormulier" asp-controller="Artikel">Artikel Toevoegen</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Index" asp-controller="Artikel">Artikel Zoeken</a>
        </div>
        <div class="col-sm card m-4">
            <h2>Categoriebeheer</h2>
            <a class="btn btn-primary m-1" asp-action="Index" asp-controller="Categorie">Alle Categorieën</a>
            <a class="btn btn-primary m-1  disabled" asp-action="Toevoegen" asp-controller="Categorie">Categorie Toevoegen</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Index" asp-controller="Categorie">Categorie Zoeken</a>
        </div>
    </div>
    <div class="row">
        <div class="col-sm card m-4">
            <h2>Bestellingen</h2>
            <a class="btn btn-primary m-1" asp-action="Index" asp-controller="Bestelling">Alle Bestellingen</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Toevoegen" asp-controller="Bestelling">Bestelling Toevoegen</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Index" asp-controller="Bestelling">Bestelling Zoeken</a>
        </div>
        <div class="col-sm card m-4">
            <h2>Klanten</h2>
            <a class="btn btn-primary m-1" asp-action="Index" asp-controller="Klant">Alle Klanten</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Zoeken" asp-controller="Klant">Klant Toevoegen</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Index" asp-controller="Klant">Klant Zoeken</a>
        </div>

    </div>
    <div class="row">
        <div class="col-sm card m-4">
            <h2>Actiecodes</h2>
            <a class="btn btn-primary m-1" asp-action="Index" asp-controller="Actiecode">Alle Codes</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Index" asp-controller="Actiecode">Actiecode Toevoegen</a>
            <a class="btn btn-primary m-1 disabled" asp-action="Index" asp-controller="Actiecode">Actiecode Zoeken</a>
        </div>
    </div>
</main>
